# OPNBOSS_SECRET_KEY: Required for storing encrypted firewall credentials in the DB.
# Generate with: opnboss gen-key
# Then export: export OPNBOSS_SECRET_KEY=<your-key>
# Without this, firewalls are read from this YAML file only.

firewalls:
  - firewall_id: "firewall1"
    host: "192.168.1.1"
    api_key: "${FW1_API_KEY}"
    api_secret: "${FW1_API_SECRET}"
    verify_ssl: false
    role: "primary"
    enabled: true
    timeout_seconds: 10

  - firewall_id: "firewall2"
    host: "192.168.1.2"
    api_key: "${FW2_API_KEY}"
    api_secret: "${FW2_API_SECRET}"
    verify_ssl: false
    role: "backup"
    enabled: true   # kept enabled; offline state handled gracefully
    timeout_seconds: 5

scheduler:
  poll_interval_minutes: 5
  retention_days: 30

api:
  host: "0.0.0.0"
  port: 8080

database:
  url: "sqlite+aiosqlite:///data/opn_boss.db"

logging:
  level: "INFO"
  format: "json"  # json or text

llm:
  enabled: true
  model: "phi3:mini"   # or llama3.2:3b, mistral:7b, qwen2.5:3b
  base_url: "http://localhost:11434"
  timeout_seconds: 120.0
