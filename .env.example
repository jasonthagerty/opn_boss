# OPNBoss Environment Configuration
# Copy this file to .env and fill in your values.

# ── Encryption Key (REQUIRED) ──────────────────────────────────────────────
# Fernet symmetric key for encrypting firewall API credentials in the database.
# Generate with:
#   docker run --rm ghcr.io/jasonthagerty/opn-boss:latest gen-key
#   # or locally:
#   uv run opnboss gen-key
#
# IMPORTANT: Back this key up. Loss means encrypted DB credentials are unrecoverable.
OPNBOSS_SECRET_KEY=

# ── Firewall Credentials (bootstrap only) ──────────────────────────────────
# Used only on the FIRST run to import firewalls from config.yaml into the database.
# After that, credentials live encrypted in the DB and these vars are no longer needed.
# Reference in config.yaml as: api_key: ${FW1_API_KEY}
FW1_API_KEY=your_firewall1_api_key_here
FW1_API_SECRET=your_firewall1_api_secret_here

FW2_API_KEY=your_firewall2_api_key_here
FW2_API_SECRET=your_firewall2_api_secret_here

# ── Optional ───────────────────────────────────────────────────────────────
# Override config file path (default: config/config.yaml)
# OPN_BOSS_CONFIG=config/config.yaml

# Log level (DEBUG, INFO, WARNING, ERROR — default: INFO)
# LOG_LEVEL=INFO
